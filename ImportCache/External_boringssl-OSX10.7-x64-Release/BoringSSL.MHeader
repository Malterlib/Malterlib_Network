	%Group OSX10.7
	{
		%Group x64
		{
			%Group "@(FullConfiguration)"
			{
				%Group crypto
				{
					%Group ec
					{
						%File "@(Target:Target.IntermediateDirectory->MakeAbsolute())/crypto/ec/p256-x86_64-asm.S"
						{
							Compile.AllowNonExisting true
							Compile.Type Assembler
						}
						%File "crypto/ec/p256-x86_64-asm.S.rule"
						{
							Compile
							{
								Custom_WorkingDirectory "@('crypto/ec'->MakeAbsolute())"
								Custom_Outputs "@(Target:Target.IntermediateDirectory->MakeAbsolute())/crypto/ec/p256-x86_64-asm.S"
								Custom_Inputs "@('../../../../External/boringssl/crypto/ec/asm/p256-x86_64-asm.pl'->MakeAbsolute());@('../../../../External/boringssl/crypto/perlasm/arm-xlate.pl'->MakeAbsolute());@('../../../../External/boringssl/crypto/perlasm/ppc-xlate.pl'->MakeAbsolute());@('../../../../External/boringssl/crypto/perlasm/x86_64-xlate.pl'->MakeAbsolute());@('../../../../External/boringssl/crypto/perlasm/x86asm.pl'->MakeAbsolute());@('../../../../External/boringssl/crypto/perlasm/x86gas.pl'->MakeAbsolute());@('../../../../External/boringssl/crypto/perlasm/x86masm.pl'->MakeAbsolute());@('../../../../External/boringssl/crypto/perlasm/x86nasm.pl'->MakeAbsolute())"
								Custom_CommandLine "perl @('../../../../External/boringssl/crypto/ec/asm/p256-x86_64-asm.pl'->MakeAbsolute()) macosx @(Target:Target.IntermediateDirectory->MakeAbsolute())/crypto/ec/p256-x86_64-asm.S"
