%Target Exe_crypto_test
{
	Compile
	{
		!!Compile.Type C++
		SearchPath "@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@('../../../../External/boringssl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;NDEBUG;@(Compile.PreprocessorDefines)"
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/BoringSSL"
	Target.Type ConsoleExecutable
	Target.BaseName crypto_test
	%Group crypto
	{
		%Group dh
		{
			%File "../../../../External/boringssl/crypto/dh/dh_test.cc"
			{
				Compile.Type C++
			}
		}
		%Group dsa
		{
			%File "../../../../External/boringssl/crypto/dsa/dsa_test.cc"
			{
				Compile.Type C++
			}
		}
		%Group test
		{
			%File "../../../../External/boringssl/crypto/test/gtest_main.cc"
			{
				Compile.Type C++
			}
			%File "../../../../External/boringssl/crypto/test/file_test.cc"
			{
				Compile.Type C++
			}
			%File "../../../../External/boringssl/crypto/test/malloc.cc"
			{
				Compile.Type C++
			}
			%File "../../../../External/boringssl/crypto/test/test_util.cc"
			{
				Compile.Type C++
			}
		}
	}
	%Dependency Lib_crypto
	%Dependency Lib_gtest
}
