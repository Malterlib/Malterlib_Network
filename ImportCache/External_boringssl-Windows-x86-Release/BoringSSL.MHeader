Property.CMakeOutputPath_BoringSSL "@('.'->MakeAbsolute())"
%Target Lib_boringssl_gtest
{
	Compile
	{
		!!Compile.Type C++
		SearchPath "@('../../../../External/boringssl/third_party/googletest'->MakeAbsolute());@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;NOMINMAX;WIN32_LEAN_AND_MEAN;_CRT_SECURE_NO_WARNINGS;_HAS_EXCEPTIONS=0;@(Compile.PreprocessorDefines)"
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/BoringSSL"
	{
		!!Target.Group ""
	}
	Target.Type StaticLibrary
	Target.BaseName boringssl_gtest
	%Group third_party
	{
		%File "../../../../External/boringssl/third_party/googletest/src/gtest-all.cc"
		{
			Compile.Type C++
		}
	}
}
%Target Lib_crypto
{
	Compile
	{
		!!Compile.Type C++
		SearchPath "@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@('../../../../External/boringssl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;NOMINMAX;WIN32_LEAN_AND_MEAN;_CRT_SECURE_NO_WARNINGS;_HAS_EXCEPTIONS=0;@(Compile.PreprocessorDefines)"
	}
	Compile
	{
		!!Compile.Type C
		SearchPath "@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@('../../../../External/boringssl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;NOMINMAX;WIN32_LEAN_AND_MEAN;_CRT_SECURE_NO_WARNINGS;_HAS_EXCEPTIONS=0;@(Compile.PreprocessorDefines)"
	}
	Compile
	{
		!!Compile.Type AssemblerNasm
		SearchPath "@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@('../../../../External/boringssl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;NDEBUG;NOMINMAX;WIN32_LEAN_AND_MEAN;_CRT_SECURE_NO_WARNINGS;_HAS_EXCEPTIONS=0;@(Compile.PreprocessorDefines)"
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/BoringSSL"
	{
		!!Target.Group ""
	}
	Target.Type StaticLibrary
	Target.BaseName crypto
