	%Dependency Lib_test_support_lib
	%Dependency Lib_crypto
	%Dependency Lib_boringssl_gtest
	%Group Windows
	{
		%Group x86
		{
			%Group "@(FullConfiguration)"
			{
				%File "@(Target:Target.IntermediateDirectory->MakeAbsolute())/crypto_test_data.cc"
				{
					Compile.AllowNonExisting true
					Compile.Type C++
				}
				%File "crypto_test_data.cc.rule"
				{
					Compile
					{
