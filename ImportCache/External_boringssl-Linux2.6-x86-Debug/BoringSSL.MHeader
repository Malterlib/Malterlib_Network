Property.CMakeOutputPath_BoringSSL "@('.'->MakeAbsolute())"
%Target Lib_gtest
{
	Compile
	{
		!!Compile.Type C++
		SearchPath "@('../../../../External/boringssl/third_party/googletest'->MakeAbsolute());@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;@(Compile.PreprocessorDefines)"
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/BoringSSL"
	Target.Type StaticLibrary
	Target.BaseName gtest
	%Group third_party
	{
		Compile.Type C++
	}
}
%Target Lib_crypto
{
	Compile
	{
		!!Compile.Type C++
		SearchPath "@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@('../../../../External/boringssl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;@(Compile.PreprocessorDefines)"
	}
	Compile
	{
		!!Compile.Type C
		SearchPath "@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@('../../../../External/boringssl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;_XOPEN_SOURCE=700;@(Compile.PreprocessorDefines)"
	}
	Compile
	{
		!!Compile.Type Assembler
		SearchPath "@('../../../../External/boringssl/third_party/googletest/include'->MakeAbsolute());@('../../../../External/boringssl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "BORINGSSL_IMPLEMENTATION;@(Compile.PreprocessorDefines)"
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/BoringSSL"
	Target.Type StaticLibrary
	Target.BaseName crypto
